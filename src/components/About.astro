---
import { siteConfig } from "../config";
---

<section id="about" class="bg-white text-navy-800 py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-4">
      <span class="text-accent-blue font-bold text-sm tracking-wider uppercase">About Me</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      <!-- Left Column -->
      <div>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-8">
          Engineering Mindset.<br />
          Analytical Approach.<br />
          Strategic Vision.
        </h2>
        
        <div class="text-gray-600 space-y-4 text-lg leading-relaxed">
          <p>{siteConfig.aboutMe}</p>
          <p>
            I enjoy working at the intersection of engineering and manufacturing, driving efficiency, solving real-world problems, and creating impactful solutions.
          </p>
        </div>
      </div>

      <!-- Right Column (Image/Graphic) -->
      <div class="relative w-full aspect-[4/3] sm:w-[80%] mx-auto lg:w-full lg:aspect-square flex justify-end">
        <!-- Main Image shape -->
        <div class="w-full h-full max-h-[400px] rounded-[3rem] rounded-tr-none bg-gray-200 overflow-hidden relative shadow-xl">
           <!-- Placeholder for an industrial/engineering image -->
           <img src="/about_machinery.png" alt="Engineering Facility" class="w-full h-full object-cover" />
           <div class="absolute inset-0 bg-navy-800/10"></div>
        </div>
      </div>
    </div>

    <!-- 4 Features Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mt-24">
      
      <div class="space-y-4">
        <div class="w-12 h-12 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
        </div>
        <h3 class="font-bold text-xl text-navy-800">Problem Solver</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Analytical thinking and structured approach to overcome complex engineering challenges.</p>
      </div>

      <div class="space-y-4">
        <div class="w-12 h-12 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
        </div>
        <h3 class="font-bold text-xl text-navy-800">Quick Learner</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Adapt quickly to new tools, software (like ANSYS), and manufacturing technologies.</p>
      </div>

      <div class="space-y-4">
        <div class="w-12 h-12 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>
        </div>
        <h3 class="font-bold text-xl text-navy-800">Team Player</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Collaborative mindset with cross-functional teams to drive quality and zero-defect initiatives.</p>
      </div>

      <div class="space-y-4">
        <div class="w-12 h-12 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" /><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" /></svg>
        </div>
        <h3 class="font-bold text-xl text-navy-800">Impact Driven</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Focused on delivering measurable business value and reducing cycle times significantly.</p>
      </div>

    </div>
  </div>
</section>
