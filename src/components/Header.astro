---
import { siteConfig } from "../config";

const initials = siteConfig.name.split(' ').map(n => n[0]).join('');
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-navy-800 text-white border-b border-white/10"
>
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3">
      <div class="w-10 h-10 rounded bg-navy-700 flex items-center justify-center font-bold text-accent-blue border border-white/10">
        {initials}
      </div>
      <span class="font-semibold text-lg tracking-wide hidden sm:block">{siteConfig.name}</span>
    </a>

    <!-- Navigation Links -->
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-300">
      <li><a href="#" class="hover:text-white transition-colors">Home</a></li>
      <li><a href="#about" class="hover:text-white transition-colors">About</a></li>
      <li><a href="#experience" class="hover:text-white transition-colors">Experience</a></li>
      <li><a href="#projects" class="hover:text-white transition-colors">Projects</a></li>
      <li><a href="#skills" class="hover:text-white transition-colors">Skills</a></li>
      <li><a href="#certifications" class="hover:text-white transition-colors">Certifications</a></li>
      <li><a href="#contact" class="hover:text-white transition-colors">Contact</a></li>
    </ul>

    <!-- Resume Button -->
    <a
      href="/Arunachalam_Senthil_CV.pdf"
      target="_blank"
      class="hidden sm:inline-block bg-accent-blue hover:bg-accent-hover text-white px-5 py-2.5 rounded-md text-sm font-medium transition-colors shadow-lg shadow-accent-blue/20"
    >
      Resume
    </a>
    
    <!-- Mobile Menu Toggle (Placeholder) -->
    <button class="md:hidden text-gray-300 hover:text-white">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 20) {
      header?.classList.add("bg-navy-900/90", "backdrop-blur-md", "shadow-md");
      header?.classList.remove("bg-navy-800");
    } else {
      header?.classList.remove("bg-navy-900/90", "backdrop-blur-md", "shadow-md");
      header?.classList.add("bg-navy-800");
    }
  });
</script>
