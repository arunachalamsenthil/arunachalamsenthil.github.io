---
import { siteConfig } from "../config";
---

<section id="certifications" class="bg-white text-navy-800 py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6">
    
    <!-- Certifications Grid -->
    <div class="mb-20">
      <div class="mb-10">
        <span class="text-accent-blue font-bold text-sm tracking-wider uppercase mb-2 block">Certifications</span>
        <h2 class="text-3xl md:text-4xl font-bold">Certifications & Courses</h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {siteConfig.certifications.map((cert) => (
          <div class="bg-white border border-gray-100 shadow-sm hover:shadow-md transition-shadow rounded-xl p-6 flex flex-col items-center text-center h-full">
            <div class="w-16 h-16 mb-4 rounded-full bg-blue-50 flex items-center justify-center text-accent-blue font-bold text-xl border border-blue-100">
               {cert.issuer.charAt(0)}
            </div>
            <h3 class="font-bold text-sm text-navy-800 mb-1">{cert.name}</h3>
            <p class="text-xs text-gray-500 mb-2">{cert.issuer}</p>
            <p class="text-xs text-gray-400 mt-auto">{cert.year}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Education and Achievements Split -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      
      <!-- Education -->
      <div>
        <div class="mb-8">
          <span class="text-accent-blue font-bold text-sm tracking-wider uppercase mb-2 block">Education</span>
          <h2 class="text-2xl font-bold">Academic Background</h2>
        </div>
        
        <div class="space-y-8">
          {siteConfig.education.map((edu) => (
            <div class="flex gap-4">
              { (edu.school && (edu.school.includes('Tiruchirappalli') || edu.school.includes('Trichy') || edu.school.includes('NIT'))) ? (
                <img src="https://tse2.mm.bing.net/th/id/OIP.JCwAIk5M7hn62mrFD2zINwAAAA?cb=thfc1&rs=1&pid=ImgDetMain&o=7&rm=3" alt="NIT Trichy logo" class="w-16 h-16 shrink-0 object-contain rounded border border-gray-200 p-1 bg-white" />
              ) : (
                <div class="w-16 h-16 shrink-0 rounded bg-surface-muted border border-gray-200 flex items-center justify-center font-bold text-navy-800 p-2 text-center text-[10px] leading-tight">
                  {edu.school.split(' ').map(w=>w[0]).slice(0,3).join('')}
                </div>
              )}
              <div>
                <h3 class="font-bold text-navy-800">{edu.degree}</h3>
                <p class="text-sm text-gray-600 mb-1">{edu.school}</p>
                <div class="text-xs font-medium text-gray-500 mb-2">{edu.dateRange}</div>
                {edu.achievements.map(ach => (
                  <p class="text-sm text-accent-blue font-medium">{ach}</p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Achievements -->
      <div>
        <div class="mb-8">
          <span class="text-accent-blue font-bold text-sm tracking-wider uppercase mb-2 block">Achievements</span>
          <h2 class="text-2xl font-bold">Awards & Honors</h2>
        </div>
        
        <ul class="space-y-4 text-gray-600 text-sm">
          {siteConfig.achievements.map((ach) => (
            <li class="flex items-start gap-3">
              <span class="text-accent-blue mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                </svg>
              </span>
              <span class="leading-relaxed font-medium">{ach}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

  </div>
</section>
