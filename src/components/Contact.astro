---
import { siteConfig } from "../config";
---

<section id="contact" class="bg-surface-muted text-navy-800 py-20 lg:py-28 border-t border-gray-200">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <span class="text-accent-blue font-bold text-sm tracking-wider uppercase mb-2 block">Contact</span>
    <h2 class="text-3xl md:text-4xl font-bold mb-6">Let's Connect</h2>
    <p class="text-gray-600 mb-10 text-lg">
      I'm always open to discussing new opportunities, collaborations, or interesting projects.
    </p>

    <div class="flex flex-col md:flex-row justify-center items-center gap-8">
      <div class="flex items-center gap-3 bg-white px-6 py-4 rounded-xl shadow-sm border border-gray-100">
        <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        </div>
        <span class="text-gray-600 font-medium">{siteConfig.social.email}</span>
      </div>

      <div class="flex items-center gap-3 bg-white px-6 py-4 rounded-xl shadow-sm border border-gray-100">
        <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.89-1.554-5.267-3.93-6.822-6.822l1.293-.97c.362-.271.527-.733.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
        </div>
        <span class="text-gray-600 font-medium">{siteConfig.contact.phone}</span>
      </div>
    </div>
  </div>
</section>
