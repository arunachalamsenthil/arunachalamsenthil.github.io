---
import { siteConfig } from "../config";
---

<section id="experience" class="bg-surface-muted text-navy-800 py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12">
      <div>
        <span class="text-accent-blue font-bold text-sm tracking-wider uppercase mb-2 block">Experience</span>
        <h2 class="text-3xl md:text-4xl font-bold">Work Experience</h2>
      </div>
      <a href="/Arunachalam_S_CV.pdf" target="_blank" class="mt-4 md:mt-0 bg-accent-blue hover:bg-accent-hover text-white px-6 py-2.5 rounded-md text-sm font-medium transition-colors">
        View Resume
      </a>
    </div>

    <div class="relative max-w-4xl">
      <!-- Vertical Line -->
      <div class="absolute left-[28px] top-[40px] bottom-0 w-0.5 bg-gray-200 z-0"></div>

      <div class="space-y-12 relative z-10">
        {siteConfig.experience.map((job, index) => (
          <div class="flex gap-6 group">
            <!-- Logo Box -->
            <div class="w-14 h-14 shrink-0 rounded-lg bg-white border border-gray-200 shadow-sm flex items-center justify-center p-2 relative z-10">
              <!-- Initials as Logo -->
              <span class="text-accent-blue font-bold text-lg">{job.company.substring(0,2).toUpperCase()}</span>
            </div>
            
            <!-- Content -->
            <div class="flex-1 pb-4">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-2 gap-2">
                <div>
                  <h3 class="text-xl font-bold text-navy-800">{job.title}</h3>
                  <p class="text-gray-600 font-medium">{job.company}</p>
                </div>
                <div class="text-sm font-medium text-gray-500 whitespace-nowrap">
                  {job.dateRange}
                </div>
              </div>
              
              <ul class="mt-4 space-y-2 text-gray-600 text-sm">
                {job.bullets.map((bullet) => (
                  <li class="flex items-start gap-2">
                    <span class="text-accent-blue mt-1.5 opacity-60 text-xs">●</span>
                    <span class="leading-relaxed">{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
