---
import { siteConfig } from "../config";
const initials = siteConfig.name.split(' ').map(n => n[0]).join('');
---

<footer class="bg-navy-900 border-t border-white/5 py-12">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-center text-center md:text-left">
      
      <!-- Left: Logo & Name -->
      <div class="flex flex-col items-center md:items-start gap-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded bg-navy-800 flex items-center justify-center font-bold text-accent-blue border border-white/10">
            {initials}
          </div>
          <span class="font-bold text-white tracking-wide">{siteConfig.name}</span>
        </div>
        <p class="text-sm text-gray-400 max-w-xs leading-relaxed">
          {siteConfig.title} | {siteConfig.skills.manufacturing[0]}
        </p>
      </div>

      <!-- Middle: Quick Links -->
      <div class="flex flex-col items-center">
        <h4 class="text-white font-semibold mb-4">Quick Links</h4>
        <ul class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm text-gray-400">
          <li><a href="#" class="hover:text-accent-blue transition-colors">Home</a></li>
          <li><a href="#about" class="hover:text-accent-blue transition-colors">About</a></li>
          <li><a href="#experience" class="hover:text-accent-blue transition-colors">Experience</a></li>
          <li><a href="#projects" class="hover:text-accent-blue transition-colors">Projects</a></li>
          <li><a href="#skills" class="hover:text-accent-blue transition-colors">Skills</a></li>
          <li><a href="#contact" class="hover:text-accent-blue transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Right: Social -->
      <div class="flex flex-col items-center md:items-end">
        <h4 class="text-white font-semibold mb-4">Follow Me</h4>
        <div class="flex gap-4">
          <a href={siteConfig.social.linkedin} target="_blank" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-accent-blue transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
          <a href={siteConfig.social.github} target="_blank" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-accent-blue transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          </a>
          <a href={`mailto:${siteConfig.social.email}`} class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-accent-blue transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </a>
        </div>
      </div>

    </div>

    <div class="mt-12 pt-8 border-t border-white/10 text-center text-sm text-gray-500">
      <p>&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
