---
import { siteConfig } from "../config";
---

<section id="projects" class="bg-surface-muted text-navy-800 py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12">
      <div>
        <span class="text-accent-blue font-bold text-sm tracking-wider uppercase mb-2 block">Projects</span>
        <h2 class="text-3xl md:text-4xl font-bold">Featured Projects</h2>
      </div>
      <a href="#" class="mt-4 md:mt-0 bg-accent-blue hover:bg-accent-hover text-white px-6 py-2.5 rounded-md text-sm font-medium transition-colors">
        View All Projects
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {siteConfig.projects.map((project, index) => (
        <div class="bg-white rounded-2xl overflow-hidden shadow-lg border border-gray-100 hover:shadow-xl transition-shadow flex flex-col h-full">
          <!-- Card Image Placeholder -->
          <div class="h-48 bg-gray-200 relative overflow-hidden">
             <!-- Different placeholder image per card based on index -->
             <img 
               src={`/project_${index + 1}.png`} 
               alt={project.name} 
               class="w-full h-full object-cover" 
             />
          </div>
          
          <div class="p-6 flex flex-col flex-grow">
            <h3 class="text-lg font-bold text-navy-800 mb-2">{project.name}</h3>
            <p class="text-gray-500 text-sm mb-6 leading-relaxed flex-grow">
              {project.description}
            </p>
            
            <!-- Skills Badges -->
            <div class="flex flex-wrap gap-2 mt-auto">
              {project.skills.map(skill => (
                <span class="bg-blue-50 text-accent-blue border border-blue-100 text-xs font-semibold px-2.5 py-1 rounded-md">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
