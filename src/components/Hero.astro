---
import { siteConfig } from "../config";
---

<section id="hero" class="bg-navy-800 text-white py-20 lg:py-28 relative overflow-hidden">
  <!-- Abstract gear/circuit watermark background (optional) -->
  <div class="absolute right-0 top-0 opacity-5 pointer-events-none w-1/2 h-full flex justify-end">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" class="w-[800px] h-[800px] -mr-40 -mt-20">
      <path fill="#FFFFFF" d="M44.7,-76.4C58.9,-69.2,71.8,-59.1,81.3,-46.3C90.8,-33.5,96.8,-18.1,97.6,-2.4C98.4,13.3,94,29.3,84.4,42.4C74.8,55.5,60,65.7,44.9,74C29.8,82.3,14.9,88.7,0.4,87.9C-14.1,87.2,-28.2,79.4,-42.6,70.8C-57,62.2,-71.7,52.8,-80.6,39.6C-89.5,26.4,-92.6,9.4,-90.1,-6.6C-87.6,-22.6,-79.5,-37.6,-68.6,-49.6C-57.7,-61.6,-44,-70.6,-29.9,-77.4C-15.8,-84.2,-1.3,-88.8,12.8,-86.3C26.9,-83.8,41,-74.2,44.7,-76.4Z" transform="translate(100 100) scale(1.1)" />
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Text Content -->
      <div class="space-y-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight">
          <span class="block text-gray-200">{siteConfig.title}</span>
          <span class="block text-gray-200">Building Solutions.</span>
          <span class="block text-accent-blue mt-2">Driving Impact.</span>
        </h1>
        
        <p class="text-gray-400 text-lg md:text-xl max-w-xl leading-relaxed">
          Mechanical Engineer with expertise in manufacturing, FEA, process optimization and engineering analytics. Passionate about solving complex problems and creating value through data-driven decisions.
        </p>

        <div class="flex flex-wrap items-center gap-4 pt-4">
          <a href="#projects" class="bg-accent-blue hover:bg-accent-hover text-white px-8 py-3.5 rounded-md font-medium transition-colors shadow-lg shadow-accent-blue/25">
            View My Work
          </a>
          <a href="/Arunachalam_S_CV.pdf" target="_blank" class="bg-transparent hover:bg-white/5 border border-white/20 text-white px-8 py-3.5 rounded-md font-medium transition-colors flex items-center gap-2">
            Download Resume
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Image Content (Placeholder) -->
      <div class="hidden lg:flex justify-end">
        <div class="relative w-80 h-[450px] rounded-t-full bg-navy-700 border-b-0 border-4 border-navy-800 shadow-2xl overflow-hidden shadow-black/50">
          <div class="absolute inset-0 bg-gradient-to-t from-navy-900 to-transparent z-10"></div>
          <!-- Since we don't have a specific portrait, we leave a sleek placeholder silhouette or use an abstract graphic -->
          <div class="w-full h-full flex flex-col justify-end items-center">
            <img src="/aruna.jpg" alt="Arunachalam S" class="w-full h-full object-cover object-top" />
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="mt-20 pt-10 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">1+</div>
          <div class="text-xs text-gray-400 font-medium">Years Experience</div>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776" /></svg>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">{siteConfig.projects.length}+</div>
          <div class="text-xs text-gray-400 font-medium">Projects Completed</div>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" /></svg>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">9+</div>
          <div class="text-xs text-gray-400 font-medium">Tools & Technologies</div>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center text-accent-blue">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">100%</div>
          <div class="text-xs text-gray-400 font-medium">Dedication</div>
        </div>
      </div>
    </div>
  </div>
</section>
